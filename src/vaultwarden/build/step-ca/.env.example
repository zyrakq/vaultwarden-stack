# Generated by stackbuilder from concatenated .env.example files
# Source files: base/.env.example, step-ca/.env.example, oidc/.env.example, smtp/.env.example, step-ca-trust/.env.example

# === BASE CONFIGURATION ===
# Project name for Docker Compose
COMPOSE_PROJECT_NAME=vaultwarden

# Docker image
IMAGE=vaultwarden/server:latest

# Logging
LOG_MAX_SIZE=10m
LOG_MAX_FILE=3
LOG_COMPRESS=true

# plain text
## openssl rand -base64 48
### ADMIN_TOKEN=CmUe9fo+agUsnIXnxVFlZatgGZgZ+ZBL5ZjPaSIdWpV4RgIuqZHTFTTsVOPsSVI8
# Using the OWASP minimum recommended settings
## echo -n "MySecretPassword" | argon2 "$(openssl rand -base64 32)" -e -id -k 19456 -t 2 -p 1
ADMIN_TOKEN='$argon2id$v=19$m=19456,t=2,p=1$cjlPc0s1OC9hc1VNRXVzb0FHQ1ZpWGljTWEvdkE0MkdzdTNjd085V2QvUT0$X+zGvGWBf+YU/PO0AStsW1EKYT3U+1mu2nHFcnOv54M'
# Registration
SIGNUPS_ALLOWED=true
INVITATIONS_ALLOWED=true
# === STEP CA CONFIGURATION ===
DOMAIN=https://vaultwarden.local
# Nginx proxy configuration
VIRTUAL_PORT=80
VIRTUAL_HOST=vaultwarden.local
VIRTUAL_PROTO=https

# Step CA SSL configuration
LETSENCRYPT_HOST=vaultwarden.local
LETSENCRYPT_EMAIL=john.smith@mail.com
# OIDC
## https://github.com/dani-garcia/vaultwarden/wiki/Enabling-SSO-support-using-OpenId-Connect
## Redirect URL: https://idm.example.com/identity/connect/oidc-signin

SSO_ENABLED=true
SSO_ONLY=true
SSO_SIGNUPS_MATCH_EMAIL=true
SSO_ALLOW_UNKNOWN_EMAIL_VERIFICATION=false
SSO_AUTH_ONLY_NOT_SESSION=false

# Kanidm
SSO_SCOPES="openid profile email"
SSO_PKCE=true
SSO_CLIENT_ID=vaultwarden
SSO_CLIENT_SECRET=6ul1oomy2jiFFSroWanEJYbVxuP3jGz8
SSO_AUTHORITY=https://idm.example.com/oauth2/openid/vaultwarden

SSO_CLIENT_CACHE_EXPIRATION=0

SSO_DEBUG_TOKENS=false
LOG_LEVEL=info
# SSO_DEBUG_TOKENS=true
# LOG_LEVEL=info,vaultwarden::sso=debug

# SSO_AUTHORIZE_EXTRA_PARAMS=
# SSO_AUDIENCE_TRUSTED=
# SSO_MASTER_PASSWORD_POLICY=
# OIDC
## https://github.com/dani-garcia/vaultwarden/wiki/SMTP-Configuration

SMTP_HOST=smtp.domain.tld
SMTP_FROM=vaultwarden@domain.tld
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_USERNAME=vaultwarden
SMTP_PASSWORD=NVZavjtpBNA9zKjNkWxcuzebF9yCn7fE
#Step CA Trust
STEP_CA_TRUST=true
STEP_CA_TRUST_RESTART=true